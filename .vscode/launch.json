{
  // ADR-007: Gmail SMTP 이메일 발송용 userApi 로컬 실행 설정.
  // 메일 자격증명(MAIL_USERNAME / MAIL_PASSWORD)은 비밀이므로 이 파일에 적지 않고,
  // .vscode/.env.local (gitignore 대상) 에서 envFile 로 주입한다.
  // 최초 1회: .vscode/.env.local.example 을 .vscode/.env.local 로 복사한 뒤 본인 Gmail 주소 / App Password 로 채운다.
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "userApi (Gmail SMTP · local)",
      "request": "launch",
      "mainClass": "com.zerobase.userApi.UserApiApplication",
      "projectName": "userApi",
      "envFile": "${workspaceFolder}/.vscode/.env.local"
    }
  ]
}
